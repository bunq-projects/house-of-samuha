---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const chefs = await getCollection('chefs');
  return chefs.map(chef => ({
    params: { slug: chef.data.slug },
    props: { chef: chef.data },
  }));
}

const base = import.meta.env.BASE_URL;
const { chef } = Astro.props;
const srcset = chef.imageSrcset.map(s => `${base}${s.src} ${s.width}w`).join(', ');
---
<BaseLayout title={`${chef.name} | House of Samuha`}>
  <header class="section_product-header4 margin-vertical margin-xhuge">
    <div class="padding-global">
      <div class="container-large">
        <div class="padding-section-medium">
          <div class="product-header4_component">
            <div class="w-layout-grid product-header4_layout">
              <div class="product-header4_gallery">
                <div class="product-header4_main-image-wrapper">
                  <img
                    src={`${base}${chef.image}`}
                    loading="lazy"
                    alt={chef.name}
                    sizes="100vw"
                    srcset={srcset}
                    class="product-header4_main-image"
                  />
                </div>
              </div>
              <div class="product-header4_product-details">
                <div class="margin-bottom margin-small">
                  <h1 class="heading-style-h2 text-style-allcaps">{chef.name}</h1>
                </div>
                <div class="margin-bottom margin-small">
                  <div class="product-header4_price-wrapper">
                    <div class="product-header4_reviews-wrapper">
                      <div class="text-size-medium text-style-allcaps">{chef.tagline}</div>
                    </div>
                  </div>
                </div>
                <div class="margin-bottom margin-large">
                  <p class="text-size-regular">{chef.bio}</p>
                </div>
                {chef.upcomingEvent.name && (
                  <>
                    <div class="margin-bottom margin-small">
                      <p class="text-size-medium text-style-allcaps">Upcoming event :</p>
                      <a href={`${base}shows/${chef.upcomingEvent.slug}/`} class="w-inline-block">
                        <p class="text-size-medium text-style-allcaps">{chef.upcomingEvent.name}</p>
                      </a>
                    </div>
                    <div class="margin-bottom margin-small">
                      <div class="text-size-regular w-richtext">
                        <p>{chef.eventDescription}</p>
                      </div>
                    </div>
                  </>
                )}
                <div class="margin-vertical margin-small">
                  <a href={`${base}reserve/`} class="bl-button w-button">Reserve Your Spot</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>
</BaseLayout>
