---
const base = import.meta.env.BASE_URL;

interface Props {
  name: string;
  slug: string;
  tagline: string;
  image: string;
  imageSrcset: { src: string; width: number }[];
}

const { name, slug, tagline, image, imageSrcset } = Astro.props;
const srcset = imageSrcset.map(s => `${base}${s.src} ${s.width}w`).join(', ');
---
<div role="listitem" class="w-dyn-item">
  <a href={`${base}chefs/${slug}/`} class="team8_item w-inline-block">
    <div class="margin-bottom margin-xxsmall">
      <div class="team8_image-wrapper">
        <img
          loading="lazy"
          alt={name}
          src={`${base}${image}`}
          srcset={srcset}
          sizes="100vw"
          class="team8_image"
        />
      </div>
    </div>
    <div>
      <div class="team8_title-wrapper">
        <div class="text-size-medium text-style-allcaps">{name}</div>
        <div class="text-size-small">{tagline}</div>
      </div>
    </div>
  </a>
</div>
